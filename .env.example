APP_NAME="Nokta Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nokta_platform
DB_USERNAME=root
DB_PASSWORD=

# Cache / Queue / Sessions -> Redis (pre-caching for kanban & hot reads)
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

# Real-time (Reverb) — channels MUST be tenant-prefixed
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

# Search / reporting (Scout + Meilisearch)
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

# Multi-tenancy
TENANCY_RESOLVER=token        # token | domain
TENANCY_CENTRAL_DOMAIN=localhost

# Integrations (optional in early phases)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
EXPRESS_WHATSAPP_URL=
