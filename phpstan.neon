includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 8
    paths:
        - app
        - database
        - routes
    # Enforce strong typing (no loose arrays / mixed across layers — see TECHNICAL-STRUCTURE).
    # Missing iterable value types are reported by default at this level in PHPStan 2.x.
    treatPhpDocTypesAsCertain: true
